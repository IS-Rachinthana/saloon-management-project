generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleKey {
  CLIENT
  HAIRDRESSER
  RECEPTIONIST
  MANAGER
  SUPER_ADMIN
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  READ
}

enum BookingRequestStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  fullName          String
  phone             String?
  avatarUrl         String?
  preferredLanguage String?         @default("en")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  roles             UserRole[]
  employee          Employee?
  customer          Customer?
  notifications     Notification[]
  feedbackEntries   Feedback[]
  auditLogs         AuditLog[]
}

model Role {
  id          String     @id @default(cuid())
  key         RoleKey    @unique
  name        String
  description String?
  users       UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  branchId  String?
  createdAt DateTime @default(now())
  branch    Branch?  @relation(fields: [branchId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, branchId])
}

model Branch {
  id            String                @id @default(cuid())
  name          String
  slug          String                @unique
  phone         String?
  email         String?
  addressLine1  String?
  city          String?
  description   String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  businessHours BranchBusinessHours[]
  employees     EmployeeBranch[]
  services      BranchService[]
  bookingRequests BookingRequest[]
  offers        Offer[]
  customers     Customer[]
  appointments  Appointment[]
  leaveRequests LeaveRequest[]
  holidays      Holiday[]
  notifications Notification[]
  userRoles     UserRole[]
}

model Employee {
  id             String                  @id @default(cuid())
  userId         String                  @unique
  jobTitle       String?
  bio            String?
  isActive       Boolean                 @default(true)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches       EmployeeBranch[]
  workingHours   EmployeeWorkingHours[]
  breakRules     EmployeeBreakRule[]
  leaveRequests  LeaveRequest[]
  availabilities EmployeeAvailability[]
  appointments   Appointment[]           @relation("AssignedEmployeeAppointments")
  bookingRequests BookingRequest[]       @relation("AssignedBookingRequests")
  statusHistory  AppointmentStatusLog[]
}

model EmployeeBranch {
  id         String   @id @default(cuid())
  employeeId String
  branchId   String
  isPrimary  Boolean  @default(false)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  services    Service[]
}

model Service {
  id               String                 @id @default(cuid())
  categoryId       String
  code             String?                @unique
  name             String
  slug             String                 @unique
  description      String?
  durationMinutes  Int
  bufferMinutes    Int                    @default(15)
  isActive         Boolean                @default(true)
  category         ServiceCategory        @relation(fields: [categoryId], references: [id])
  branches         BranchService[]
  appointmentItems AppointmentService[]
  subItems         ServiceSubItem[]
  bookingItems     BookingRequestService[]
}

model ServiceSubItem {
  id                    String                  @id @default(cuid())
  serviceId             String
  code                  String                  @unique
  name                  String
  description           String?
  priceLkr              Decimal?                @db.Decimal(10, 2)
  durationMinutes       Int?
  breakMinutes          Int?
  timingNotes           String?
  isDefaultSelected     Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  service               Service                 @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  bookingRequestItems   BookingRequestSubItem[]
}

model BranchService {
  id        String   @id @default(cuid())
  branchId  String
  serviceId String
  priceLkr  Decimal  @db.Decimal(10, 2)
  isVisible Boolean  @default(true)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([branchId, serviceId])
}

model Customer {
  id                 String               @id @default(cuid())
  userId             String               @unique
  branchId           String?
  birthday           DateTime?
  hometown           String?
  livingTown         String?
  preferredBranchId  String?
  preferredStylistId String?
  loyaltyStatus      String?
  visitFrequency     String?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch             Branch?              @relation(fields: [branchId], references: [id])
  profilePhotos      CustomerPhoto[]
  preferences        CustomerPreference[]
  appointments       Appointment[]
  bookingRequests    BookingRequest[]
}

model BookingRequest {
  id                  String                   @id @default(cuid())
  customerId          String?
  branchId            String
  assignedEmployeeId  String?
  bookingDate         DateTime
  bookingTime         String
  customerName        String
  customerPhone       String
  customerEmail       String?
  notes               String?
  status              BookingRequestStatus     @default(PENDING)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  customer            Customer?                @relation(fields: [customerId], references: [id])
  branch              Branch                   @relation(fields: [branchId], references: [id])
  assignedEmployee    Employee?                @relation("AssignedBookingRequests", fields: [assignedEmployeeId], references: [id])
  services            BookingRequestService[]
  statusHistory       BookingStatusHistory[]
}

model BookingRequestService {
  id                String                  @id @default(cuid())
  bookingRequestId  String
  serviceId         String
  serviceCode       String?
  serviceName       String
  priceSnapshot     Decimal?                @db.Decimal(10, 2)
  durationMinutes   Int?
  breakMinutes      Int?
  category          String?
  bookingRequest    BookingRequest          @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  service           Service                 @relation(fields: [serviceId], references: [id])
  selectedSubItems  BookingRequestSubItem[]
}

model BookingRequestSubItem {
  id                       String                 @id @default(cuid())
  bookingRequestServiceId  String
  serviceSubItemId         String
  subItemCode              String?
  subItemName              String
  priceSnapshot            Decimal?               @db.Decimal(10, 2)
  durationMinutes          Int?
  breakMinutes             Int?
  bookingRequestService    BookingRequestService  @relation(fields: [bookingRequestServiceId], references: [id], onDelete: Cascade)
  serviceSubItem           ServiceSubItem         @relation(fields: [serviceSubItemId], references: [id])
}

model BookingStatusHistory {
  id                String               @id @default(cuid())
  bookingRequestId  String
  status            BookingRequestStatus
  changedAt         DateTime             @default(now())
  note              String?
  bookingRequest    BookingRequest       @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
}

model CustomerPhoto {
  id         String   @id @default(cuid())
  customerId String
  imageUrl   String
  caption    String?
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerPreference {
  id         String   @id @default(cuid())
  customerId String
  key        String
  value      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, key])
}

model Appointment {
  id                   String                  @id @default(cuid())
  branchId             String
  customerId           String
  assignedEmployeeId   String?
  status               AppointmentStatus       @default(PENDING)
  startAt              DateTime
  endAt                DateTime
  totalDurationMinutes Int
  totalBufferMinutes   Int                     @default(15)
  notes                String?
  isWalkIn             Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  branch               Branch                  @relation(fields: [branchId], references: [id])
  customer             Customer                @relation(fields: [customerId], references: [id])
  assignedEmployee     Employee?               @relation("AssignedEmployeeAppointments", fields: [assignedEmployeeId], references: [id])
  services             AppointmentService[]
  statusHistory        AppointmentStatusLog[]
  lock                 AppointmentLock?
  payments             Payment[]
}

model AppointmentService {
  id             String      @id @default(cuid())
  appointmentId  String
  serviceId      String
  priceSnapshot  Decimal     @db.Decimal(10, 2)
  durationMinute Int
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service        Service     @relation(fields: [serviceId], references: [id])
}

model AppointmentStatusLog {
  id            String            @id @default(cuid())
  appointmentId String
  status        AppointmentStatus
  changedById   String?
  changedAt     DateTime          @default(now())
  note          String?
  appointment   Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedBy     Employee?         @relation(fields: [changedById], references: [id])
}

model AppointmentLock {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  lockedUntil   DateTime
  token         String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model EmployeeWorkingHours {
  id         String   @id @default(cuid())
  employeeId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeBreakRule {
  id           String   @id @default(cuid())
  employeeId   String
  afterMinutes Int
  breakMinutes Int
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model EmployeeAvailability {
  id          String   @id @default(cuid())
  employeeId  String
  startAt     DateTime
  endAt       DateTime
  isAvailable Boolean  @default(true)
  note        String?
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id        String      @id @default(cuid())
  employeeId String
  branchId  String?
  startAt   DateTime
  endAt     DateTime
  leaveType String
  reason    String?
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  employee  Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch    Branch?     @relation(fields: [branchId], references: [id])
}

model BranchBusinessHours {
  id        String   @id @default(cuid())
  branchId  String
  dayOfWeek Int
  openTime  String
  closeTime String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Holiday {
  id        String   @id @default(cuid())
  branchId  String?
  title     String
  startDate DateTime
  endDate   DateTime
  branch    Branch?  @relation(fields: [branchId], references: [id])
}

model Offer {
  id        String    @id @default(cuid())
  branchId  String?
  title     String
  summary   String?
  imageUrl  String?
  startsAt  DateTime
  endsAt    DateTime
  isVisible Boolean   @default(true)
  branch    Branch?   @relation(fields: [branchId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  branchId  String?
  language  String   @default("en")
  rating    Int
  message   String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  branchId  String?
  channel   NotificationChannel
  title     String
  body      String
  status    NotificationStatus  @default(QUEUED)
  sentAt    DateTime?
  createdAt DateTime            @default(now())
  user      User?               @relation(fields: [userId], references: [id])
  branch    Branch?             @relation(fields: [branchId], references: [id])
}

model Payment {
  id            String        @id @default(cuid())
  appointmentId String
  provider      String
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("LKR")
  status        PaymentStatus @default(PENDING)
  reference     String?       @unique
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}
